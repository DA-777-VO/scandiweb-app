{
    "name": "scandiweb/backend",
    "description": "Scandiweb Full Stack Test Backend",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "webonyx/graphql-php": "^15.0",
        "nikic/fast-route": "^1.3",
        "vlucas/phpdotenv": "^5.5",
        "ext-pdo": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        },
        "psr-0": {
                "": "src/"
            }
        },
    "config": {
        "optimize-autoloader": true
    }
}
